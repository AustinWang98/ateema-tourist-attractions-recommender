# Copy this file to .env and fill in real values.
# Default LLM provider is OpenAI cloud. The app still runs without a key
# (it falls back to a deterministic schedule built from the Top picks).

# --- LLM (OpenAI-compatible API) — default: OpenAI cloud ---
OPENAI_API_KEY=sk-...            # your OpenAI secret key
OPENAI_BASE_URL=openai           # "openai" = official cloud; "ollama" = local
OPENAI_MODEL=gpt-4o-mini         # or gpt-4o for higher quality
# Free local Ollama instead: OPENAI_BASE_URL=ollama  OPENAI_MODEL=llama3.1:8b  (run `ollama serve`)
# Groq example: OPENAI_BASE_URL=https://api.groq.com/openai/v1  OPENAI_MODEL=llama-3.3-70b-versatile

# Path to the cleaned user-location-event CSV (relative to project root).
DATA_CSV_PATH=data/user_location_features.csv

# Persistent on-disk cache for LLM responses (keyed by model + prompt hash).
# Delete this file to bust the cache.
LLM_CACHE_PATH=data/llm_cache.sqlite

# Set to 0 to bypass the cache (useful while iterating on prompts).
LLM_CACHE_ENABLED=1

# --------------------------------------------------------------------------- #
# BigQuery data source (production, optional for demo deploys).
# Startup order:
#   1. BigQuery when BQ_PROJECT + BQ_DATASET are set.
#   2. Full local cache at DATA_CSV_PATH.
#   3. Public checked-in CSV fallback from location_dim/events/geo.
#
# Authentication: run `gcloud auth application-default login` once.
# Never commit the generated credentials file to git.
# --------------------------------------------------------------------------- #
BQ_PROJECT=
BQ_DATASET=
BQ_TABLE_FEATURES=user_location_full_features
BQ_TABLE_LOCATION_DIM=location_dim
BQ_TABLE_EVENTS=user_location_category_events

# Feedback-loop guard: recommender-origin outbound clicks are logged separately
# and lightly penalized so the product does not inflate its own future rankings.
FEEDBACK_GUARD_ENABLED=true
FEEDBACK_GUARD_WINDOW_DAYS=30
FEEDBACK_GUARD_STRENGTH=0.08
RECOMMENDER_OUTBOUND_CLICKS_PATH=data/outbound_clicks.jsonl
