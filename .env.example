# Copy this file to .env and fill in real values.
# Defaults target local Ollama (free). The app still runs without LLM (fallback).

# --- LLM (OpenAI-compatible API) — default: Ollama ---
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3.1:8b
# For paid OpenAI instead: OPENAI_BASE_URL=openai  OPENAI_API_KEY=sk-...  OPENAI_MODEL=gpt-4o
# Groq example: OPENAI_BASE_URL=https://api.groq.com/openai/v1  OPENAI_MODEL=llama-3.3-70b-versatile

# Path to the cleaned user-location-event CSV (relative to project root).
DATA_CSV_PATH=data/user_location_features.csv

# Persistent on-disk cache for LLM responses (keyed by model + prompt hash).
# Delete this file to bust the cache.
LLM_CACHE_PATH=data/llm_cache.sqlite

# Set to 0 to bypass the cache (useful while iterating on prompts).
LLM_CACHE_ENABLED=1

# --------------------------------------------------------------------------- #
# BigQuery data source (required).
# The app queries BigQuery on startup and on /api/refresh. If BQ is briefly
# unreachable, it falls back to the offline cache under data/*.csv, which
# you can refresh manually with `python -m backend.refresh`.
#
# Authentication: run `gcloud auth application-default login` once.
# Never commit the generated credentials file to git.
# --------------------------------------------------------------------------- #
BQ_PROJECT=
BQ_DATASET=
BQ_TABLE_FEATURES=user_location_full_features
BQ_TABLE_LOCATION_DIM=location_dim
BQ_TABLE_EVENTS=user_location_category_events
